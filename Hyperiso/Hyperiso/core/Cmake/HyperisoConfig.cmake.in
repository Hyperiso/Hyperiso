@PACKAGE_INIT@

# Record the options used to build the installed package.
set(HYPERISO_WITH_SOFTSUSY @BUILD_WITH_SOFTSUSY@)
set(HYPERISO_WITH_2HDMC    TRUE)
set(HYPERISO_WITH_MARTY    @BUILD_WITH_MARTY@)

# Resolve non-vendored dependencies from the installation environment.
# Resolve public dependencies here with find_dependency(...).
# Keep these calls disabled for dependencies shipped directly by HyperIso.
include(CMakeFindDependencyMacro)

find_dependency(GSL REQUIRED)

# Example: 2HDMC uses GSL. Enable this when GSL is not bundled.
# if(HYPERISO_WITH_2HDMC)
#   find_dependency(GSL REQUIRED)
# endif()

# Recreate imported targets for external libraries installed with HyperIso.
# Recreate imported targets that point to the installation prefix:
# This is unnecessary when the exported targets link their own static libraries.
# Example for a vendored MARTY installation:
if(HYPERISO_WITH_MARTY AND NOT TARGET Marty::marty)
  add_library(Marty::marty SHARED IMPORTED)
  set_target_properties(Marty::marty PROPERTIES
    IMPORTED_LOCATION "${PACKAGE_PREFIX_DIR}/lib/libmarty.so"
    INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/include"
  )
endif()

# Example for a vendored 2HDMC installation:
# if(HYPERISO_WITH_2HDMC AND NOT TARGET TwoHDMC::twohdmc)
#   add_library(TwoHDMC::twohdmc STATIC IMPORTED)
#   set_target_properties(TwoHDMC::twohdmc PROPERTIES
#     IMPORTED_LOCATION "${PACKAGE_PREFIX_DIR}/lib/lib2hdmc.a"
#     INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/include"
#   )
# endif()

# Load the targets exported by HyperIso.
include("${CMAKE_CURRENT_LIST_DIR}/HyperisoTargets.cmake")
